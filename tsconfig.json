{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@ns": ["./NetscriptDefinitions.d.ts"]
    }
  },
  "include": ["scripts/**/*", "tools/**/*", "NetscriptDefinitions.d.ts"]
}
